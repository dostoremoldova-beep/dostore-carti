generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model Book {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  slug           String   @unique
  author         String
  description    String
  price          Float
  discountPrice  Float?
  coverImage     String
  images         String[]
  categoryId     String   @db.ObjectId
  category       Category @relation(fields: [categoryId], references: [id])
  publisher      String?
  isbn           String?
  language       String   @default("Română")
  pageCount      Int?
  // Greutatea la ambalare, în grame. FAN Courier tarifează pe kg, deci fără ea
  // nu putem calcula corect costul livrării. Opțional: produsele fără greutate
  // intră în calcul cu estimarea implicită din lib/shipping/weight.ts.
  weightGrams    Int?
  stock          Int      @default(0)
  rating         Float    @default(0)
  reviewCount    Int      @default(0)
  isBestseller   Boolean  @default(false)
  isNew          Boolean  @default(false)
  tags           String[]
  // Întrebări frecvente specifice produsului, administrate din panoul de admin.
  // Embedded (nu model separat): aparțin exclusiv produsului, se citesc mereu
  // împreună cu el și se rescriu în bloc la salvare.
  faqs           BookFaq[]
  // Recenzii, administrate din admin. `rating` și `reviewCount` de mai sus se
  // recalculează automat din ele la salvare.
  reviews        BookReview[]
  // Specificații libere (etichetă + valoare), administrate din admin și afișate
  // ca badge-uri pe pagina produsului. Ex: „Vârstă"→„12+", „Pagini"→„300".
  specs          BookSpec[]
  searchText     String
  orderItems     OrderItem[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([categoryId])
}

model Category {
  id    String @id @default(auto()) @map("_id") @db.ObjectId
  name  String @unique
  slug  String @unique
  icon  String?
  // Imagine proprie, încărcată din admin. Când există, înlocuiește iconița
  // în listele de categorii de pe site.
  image String?
  // Ce apare în secțiunea „Categorii populare" de pe pagina principală și în
  // ce ordine — controlat din admin, nu din cod.
  featured      Boolean @default(false)
  featuredOrder Int     @default(0)
  books Book[]
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

enum PaymentStatus {
  UNPAID
  PAID
  FAILED
  REFUNDED
}

enum PaymentMethod {
  ONLINE            // plată pe site prin QR (VictoriaBank MIA)
  CARD_ON_DELIVERY  // card la livrare
  CASH_ON_DELIVERY  // numerar la livrare
}

model Order {
  id                String             @id @default(auto()) @map("_id") @db.ObjectId
  orderNumber       String             @unique
  customerName      String
  customerEmail     String
  customerPhone     String
  shippingAddress   String
  city              String
  // Raionul (province la FAN). Obligatoriu pentru AWB — se completează automat
  // din localitatea aleasă în checkout, fiindcă lista FAN dă perechea oraș+raion.
  county            String?
  items             OrderItem[]
  subtotal          Float
  shippingCost      Float
  total             Float
  status            OrderStatus        @default(PENDING)
  // Cum alege clientul să plătească: ONLINE (QR pe site), CARD_ON_DELIVERY
  // (card la livrare) sau CASH_ON_DELIVERY (numerar la livrare).
  paymentMethod     PaymentMethod      @default(ONLINE)
  paymentStatus     PaymentStatus      @default(UNPAID)
  paymentId         String?
  // Plată VictoriaBank MIA (QR). Le păstrăm ca să interogăm statusul la bancă
  // și să potrivim semnalele (webhook) cu comanda.
  qrHeaderUUID      String?
  qrExtensionUUID   String?
  qrPayUrl          String?            // payload-ul QR (link), din care regenerăm imaginea
  // Tracking livrare
  trackingNumber    String?            // AWB de la curier (FANcourier)
  estimatedDelivery DateTime?          // termen estimat de livrare
  // Cât ne costă PE NOI expedierea, după tariful din contractul FAN. Nu e ce
  // plătește clientul (acela vine din regula proprie) — se salvează ca să se
  // vadă marja reală pe fiecare comandă în admin.
  fanCost           Float?
  statusHistory     OrderStatusEvent[] // istoricul stadiilor, cu timestamp
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

// O specificație a produsului (etichetă + valoare), embedded.
type BookSpec {
  label String // ex: „Vârstă", „Pagini", „Categorie"
  value String // ex: „12+", „300", „Dezvoltare personală"
}

// O recenzie a unui produs (embedded).
type BookReview {
  author String
  rating Int      // 1–5 stele
  text   String
  date   DateTime @default(now())
}

// O întrebare frecventă atașată unui produs.
type BookFaq {
  question    String
  answer      String
  // Dacă e true, acordeonul apare deja deschis la încărcarea paginii.
  defaultOpen Boolean @default(false)
}

// Un stadiu din istoricul comenzii (embedded), pentru timeline-ul de tracking.
type OrderStatusEvent {
  status OrderStatus
  at     DateTime
}

model OrderItem {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  orderId  String @db.ObjectId
  order    Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)
  bookId   String @db.ObjectId
  book     Book   @relation(fields: [bookId], references: [id])
  title    String
  price    Float
  quantity Int

  @@index([orderId])
  @@index([bookId])
}

model Publisher {
  id   String @id @default(auto()) @map("_id") @db.ObjectId
  name String @unique
  slug String @unique
}

model Admin {
  id       String @id @default(auto()) @map("_id") @db.ObjectId
  email    String @unique
  password String
}

model NewsletterSubscriber {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  createdAt DateTime @default(now())
}

// Articol de blog, administrat complet din panoul de admin.
model BlogPost {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  slug        String    @unique
  excerpt     String    // rezumatul din listă și din meta description
  content     String    // corpul articolului, în Markdown simplu
  coverImage  String
  author      String    @default("Dostore Carti")
  tags        String[]
  // Articolele nepublicate se văd doar în admin (ciornă).
  published   Boolean   @default(true)
  publishedAt DateTime  @default(now())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([published, publishedAt])
}
